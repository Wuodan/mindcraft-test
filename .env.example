# Recommended until this issue fixed: https://github.com/mindcraft-bots/mindcraft/issues/728
MINDCRAFT_REPO=https://github.com/Wuodan/mindcraft.git
MINDCRAFT_REF=fix/728-docker-apply-patches

# Normal mindcraft source
# MINDCRAFT_REPO=https://github.com/mindcraft-bots/mindcraft.git
# MINDCRAFT_REF=develop

# Optional changes

# INIT_MESSAGE="Start autonomous goal mode: obtain and equip full diamond armor and one diamond sword while staying alive. Prioritize survival and sustainability: keep food available, avoid low-health risks, and maintain a safe base with storage. Suggested progression: basic tools -> iron tools/armor and shield -> diamond mining -> craft/equip full diamond kit. Only end the goal when full diamond armor is equipped and a diamond sword is ready."
# MC_SERVER_PORT=55916
# DYNMAP_HOST_PORT=8123
# MINDCRAFT_UI_PORT=18080
# Optional on Linux/macOS if your uid/gid is not 1000:1000
# BOT_UID=1000
# BOT_GID=1000

# Example API key in .env (all supported keys can be added the same way):
# OPENROUTER_API_KEY=sk-...
